{
  "expo": {
    "name": "Xself Home",
    "slug": "xself-home",
    "scheme": "xselfhome",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F766E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.xself.home",
      "buildNumber": "20",
      "infoPlist": {
        "NSCameraUsageDescription": "Use your camera to search for furniture and upload photos for customer support."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0F766E"
      },
      "package": "com.xself.home"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "3d5a36de-d144-4e6c-ac40-c336e8a8aac2"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Xself Home to access your photos to search similar products.",
          "cameraPermission": "Allow Xself Home to use your camera to search similar products."
        }
      ],
      "expo-secure-store",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": [
            "merchant.com.xself.home"
          ],
          "enableGooglePay": false
        }
      ],
      [
        "react-native-crisp-chat-sdk",
        {
          "websiteId": "37dc2a19-ef77-42c9-bd9a-7731033293bd"
        }
      ]
    ]
  }
}
